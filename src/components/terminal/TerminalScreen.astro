  </div>
  
  <div class="input-area">
    <div class="input-line">
      <span class="prompt">&gt;</span>
      <input 
        type="text" 
        id="terminal-input" 
        class="terminal-input" 
        autocomplete="off" 
        spellcheck="false"
        autofocus
      />
      <span class="cursor"></span>
    </div>
  </div>
</div>

<script>
  import { findCommand } from '../../data/commands';

  const outputArea = document.getElementById('output-area');
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const commandHistory: string[] = [];
  let historyIndex = -1;

  // Initialize with default command if specified in URL
  const urlParams = new URLSearchParams(window.location.search);
  const initialCmd = urlParams.get('cmd');

  // Handle command execution
  function executeCommand(cmdLine: string) {
    const trimmed = cmdLine.trim().toLowerCase();
    if (!trimmed) return;

    // Add to history
    commandHistory.push(trimmed);
    historyIndex = commandHistory.length;

    // Add command to output
    addOutput(`> ${trimmed}`, 'command');

    // Handle special commands
    if (trimmed === 'clear') {
      clearOutput();
      return;
    }

    if (trimmed === 'reboot') {
      window.location.reload();
      return;
    }

    // Find and execute command
    const command = findCommand(trimmed.split(' ')[0]);
    if (command) {
      const result = command.execute(trimmed.split(' ').slice(1));
      if (result) {
        addOutput(result, 'success');
      }
    } else {
      addOutput(`Command not found: ${trimmed}. Type 'help' for available commands.`, 'error');
    }
  }

  function addOutput(text: string, type: 'command' | 'success' | 'error' = 'success') {
    if (!outputArea) return;
    
    const div = document.createElement('div');
    div.className = `output-line ${type}-line`;
    div.textContent = text;
    outputArea.appendChild(div);
    
    // Scroll to bottom
    outputArea.scrollTop = outputArea.scrollHeight;
  }

  function clearOutput() {
    if (!outputArea) return;
    outputArea.innerHTML = '';
  }

  // Input event handling
  if (input) {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        executeCommand(input.value);
        input.value = '';
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          input.value = commandHistory[historyIndex] || '';
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex < commandHistory.length - 1) {
          historyIndex++;
          input.value = commandHistory[historyIndex] || '';
        } else {
          historyIndex = commandHistory.length;
          input.value = '';
        }
      }
    });

    // Keep focus on input
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.menu-btn')) {
        input.focus();
      }
    });
  }

  // Menu button handling
  document.querySelectorAll('.menu-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-cmd');
      if (cmd && input) {
        input.value = cmd;
        executeCommand(cmd);
        input.value = '';
      }
    });
  });

  // Execute initial command if specified
  if (initialCmd) {
    setTimeout(() => {
      executeCommand(initialCmd);
    }, 600);
  }
</script>

<style>
  .terminal-screen-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .output-area {
    flex: 1;
    overflow-y: auto;
    padding: 15px 20px;
    font-size: 1.1rem;
  }

  .welcome-message {
    margin-bottom: 20px;
  }

  .ascii-art {
    font-size: 0.7rem;
    line-height: 1;
    margin-bottom: 15px;
    color: var(--terminal-text);
  }

  .welcome-text p {
    margin: 5px 0;
  }

  .welcome-text .hint {
    color: var(--terminal-text-dim);
    margin-top: 15px;
  }

  .quick-menu {
    margin-top: 20px;
    padding-top: 15px;
    border-top: 1px solid var(--terminal-border-dim);
  }

  .menu-label {
    display: block;
    margin-bottom: 10px;
    color: var(--terminal-text-dim);
  }

  .menu-items {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .menu-btn {
    background: transparent;
    border: 1px solid var(--terminal-border);
    color: var(--terminal-text);
    padding: 5px 10px;
    font-family: 'VT323', monospace;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .menu-btn:hover {
    background-color: var(--terminal-text);
    color: var(--terminal-bg);
  }

  .input-area {
    padding: 15px 20px;
    border-top: 1px solid var(--terminal-border);
    background: linear-gradient(
      to top,
      rgba(51, 255, 0, 0.05),
      transparent
    );
  }

  .input-line {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .prompt {
    color: var(--terminal-text);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--terminal-text);
    font-family: 'VT323', monospace;
    font-size: 1.1rem;
    padding: 5px;
    caret-color: transparent;
  }

  .terminal-input::placeholder {
    color: var(--terminal-text-dim);
  }

  /* Output line styling */
  .output-line {
    white-space: pre-wrap;
    word-wrap: break-word;
    margin: 4px 0;
    line-height: 1.4;
  }

  .command-line {
    color: var(--terminal-text);
  }

  .error-line {
    color: #ff3333;
    text-shadow: 0 0 5px rgba(255, 51, 51, 0.5);
  }

  .success-line {
    color: var(--terminal-text);
  }
</style>
