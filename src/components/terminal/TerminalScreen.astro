---
// Main terminal screen with output and input - Pip-Boy Style Navigation
---

<div class="terminal-screen-content">
  <div id="output-area" class="output-area">
    <div class="welcome-message" id="welcome-content">
      <pre class="ascii-art glow-text">
██╗   ██╗ █████╗ ██╗   ██╗██╗  ████████╗
██║   ██║██╔══██╗██║   ██║██║  ╚══██╔══╝
██║   ██║███████║██║   ██║██║     ██║   
╚██╗ ██╔╝██╔══██║██║   ██║██║     ██║   
 ╚████╔╝ ██║  ██║╚██████╔╝███████╗██║   
  ╚═══╝  ╚═╝  ╚═╝ ╚═════╝ ╚══════╝╚═╝   
      </pre>
      <div class="welcome-text">
        <p>Welcome to ROBCO INDUSTRIES (TM) Termlink</p>
        <p>Personal Portfolio Interface v1.0.77</p>
        <p class="hint">Select a section from the menu below or type a command.</p>
      </div>
    </div>
    <div id="main-content" class="main-content"></div>
  </div>
  
  <div class="input-area">
    <div class="input-line">
      <span class="prompt" id="current-section-prompt">&gt;</span>
      <input 
        type="text" 
        id="terminal-input" 
        class="terminal-input" 
        autocomplete="off" 
        spellcheck="false"
        autofocus
      />
      <span class="cursor"></span>
    </div>
  </div>
  
  <!-- Pip-Boy Style Menu -->
  <div class="pipboy-menu">
    <div class="menu-tabs">
      <button class="menu-tab" data-cmd="about" data-section="about">
        <span class="tab-icon">◄</span>
        <span class="tab-label">STAT</span>
      </button>
      <button class="menu-tab" data-cmd="skills" data-section="skills">
        <span class="tab-icon">◈</span>
        <span class="tab-label">SKILLS</span>
      </button>
      <button class="menu-tab" data-cmd="projects" data-section="projects">
        <span class="tab-icon">◊</span>
        <span class="tab-label">DATA</span>
      </button>
      <button class="menu-tab" data-cmd="experience" data-section="experience">
        <span class="tab-icon">◉</span>
        <span class="tab-label">WORK</span>
      </button>
      <button class="menu-tab" data-cmd="contact" data-section="contact">
        <span class="tab-icon">◆</span>
        <span class="tab-label">COMMS</span>
      </button>
    </div>
  </div>
</div>

<script>
  import { findCommand, getCurrentSection, setCurrentSection, NAVIGATE_PREFIX } from '../../data/commands';

  const outputArea = document.getElementById('output-area');
  const welcomeContent = document.getElementById('welcome-content');
  const mainContent = document.getElementById('main-content');
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const sectionPrompt = document.getElementById('current-section-prompt');
  const commandHistory: string[] = [];
  let historyIndex = -1;

  // Initialize with default command if specified in URL
  const urlParams = new URLSearchParams(window.location.search);
  const initialCmd = urlParams.get('cmd');

  // Update active menu tab
  function updateActiveTab(section: string) {
    document.querySelectorAll('.menu-tab').forEach(tab => {
      tab.classList.remove('active');
      if (tab.getAttribute('data-section') === section) {
        tab.classList.add('active');
      }
    });
  }

  // Show main content area and hide welcome
  function showMainContent() {
    if (welcomeContent) {
      welcomeContent.style.display = 'none';
    }
    if (mainContent) {
      mainContent.style.display = 'block';
    }
  }

  // Show welcome screen
  function showWelcome() {
    if (welcomeContent) {
      welcomeContent.style.display = 'block';
    }
    if (mainContent) {
      mainContent.style.display = 'none';
      mainContent.innerHTML = '';
    }
    setCurrentSection('');
    updateActiveTab('');
    if (sectionPrompt) {
      sectionPrompt.textContent = '>';
    }
  }

  // Handle navigation command (replaces content)
  function navigateToSection(section: string, content: string) {
    showMainContent();
    if (mainContent) {
      mainContent.innerHTML = '';
      const div = document.createElement('div');
      div.className = 'section-content';
      div.textContent = content;
      mainContent.appendChild(div);
    }
    setCurrentSection(section);
    updateActiveTab(section);
    if (sectionPrompt) {
      sectionPrompt.textContent = `[${section.toUpperCase()}]>`;
    }
  }

  // Handle command execution
  function executeCommand(cmdLine: string) {
    const trimmed = cmdLine.trim().toLowerCase();
    if (!trimmed) return;

    // Add to history
    commandHistory.push(trimmed);
    historyIndex = commandHistory.length;

    // Handle special commands
    if (trimmed === 'clear') {
      showWelcome();
      return;
    }

    if (trimmed === 'reboot') {
      window.location.reload();
      return;
    }

    // Find and execute command
    const command = findCommand(trimmed.split(' ')[0]);
    if (command) {
      const result = command.execute(trimmed.split(' ').slice(1));
      if (result) {
        // Check if this is a navigation command
        if (typeof result === 'string' && result.startsWith(NAVIGATE_PREFIX)) {
          const parts = result.substring(NAVIGATE_PREFIX.length).split('|');
          const section = parts[0];
          const content = parts.slice(1).join('|');
          navigateToSection(section, content);
        } else {
          // Regular command - append to current view
          addOutput(result, 'success');
        }
      }
    } else {
      addOutput(`Command not found: ${trimmed}. Type 'help' for available commands.`, 'error');
    }
  }

  function addOutput(text: string, type: 'command' | 'success' | 'error' = 'success') {
    showMainContent();
    if (!mainContent) return;
    
    const div = document.createElement('div');
    div.className = `output-line ${type}-line`;
    div.textContent = text;
    mainContent.appendChild(div);
    
    // Scroll to bottom
    outputArea.scrollTop = outputArea.scrollHeight;
  }

  // Input event handling
  if (input) {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        executeCommand(input.value);
        input.value = '';
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          input.value = commandHistory[historyIndex] || '';
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex < commandHistory.length - 1) {
          historyIndex++;
          input.value = commandHistory[historyIndex] || '';
        } else {
          historyIndex = commandHistory.length;
          input.value = '';
        }
      }
    });

    // Keep focus on input
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.menu-tab')) {
        input.focus();
      }
    });
  }

  // Menu button handling - Pip-Boy style navigation
  document.querySelectorAll('.menu-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const cmd = tab.getAttribute('data-cmd');
      if (cmd) {
        executeCommand(cmd);
      }
    });
  });

  // Execute initial command if specified
  if (initialCmd) {
    setTimeout(() => {
      executeCommand(initialCmd);
    }, 600);
  }
</script>

<style>
  .terminal-screen-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .output-area {
    flex: 1;
    overflow-y: auto;
    padding: 15px 20px;
    font-size: 1.1rem;
  }

  .welcome-message {
    margin-bottom: 20px;
  }

  .ascii-art {
    font-size: 0.7rem;
    line-height: 1;
    margin-bottom: 15px;
    color: var(--terminal-text);
  }

  .welcome-text p {
    margin: 5px 0;
  }

  .welcome-text .hint {
    color: var(--terminal-text-dim);
    margin-top: 15px;
  }

  .main-content {
    display: none;
  }

  .section-content {
    white-space: pre-wrap;
    word-wrap: break-word;
    line-height: 1.4;
  }

  .input-area {
    padding: 10px 20px;
    border-top: 1px solid var(--terminal-border);
    background: linear-gradient(
      to top,
      rgba(51, 255, 0, 0.05),
      transparent
    );
  }

  .input-line {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .prompt {
    color: var(--terminal-text);
    font-size: 1.1rem;
    font-weight: bold;
    white-space: nowrap;
  }

  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--terminal-text);
    font-family: 'Share Tech Mono', 'Courier New', monospace;
    font-size: 1.1rem;
    padding: 5px;
    caret-color: transparent;
  }

  .terminal-input::placeholder {
    color: var(--terminal-text-dim);
  }

  /* Pip-Boy Style Menu */
  .pipboy-menu {
    padding: 10px 20px;
    border-top: 2px solid var(--terminal-border);
    background: rgba(51, 255, 0, 0.05);
  }

  .menu-tabs {
    display: flex;
    justify-content: space-between;
    gap: 8px;
  }

  .menu-tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 8px 4px;
    background: transparent;
    border: 1px solid var(--terminal-border-dim);
    color: var(--terminal-text-dim);
    font-family: 'Share Tech Mono', 'Courier New', monospace;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .menu-tab:hover {
    border-color: var(--terminal-text);
    color: var(--terminal-text);
    background: rgba(51, 255, 0, 0.1);
  }

  .menu-tab.active {
    border-color: var(--terminal-text);
    background: var(--terminal-text);
    color: var(--terminal-bg);
  }

  .menu-tab.active .tab-icon {
    color: var(--terminal-bg);
  }

  .tab-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .tab-label {
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

  /* Output line styling */
  .output-line {
    white-space: pre-wrap;
    word-wrap: break-word;
    margin: 4px 0;
    line-height: 1.4;
  }

  .command-line {
    color: var(--terminal-text);
  }

  .error-line {
    color: #ff3333;
    text-shadow: 0 0 5px rgba(255, 51, 51, 0.5);
  }

  .success-line {
    color: var(--terminal-text);
  }

  /* Mobile adjustments */
  @media (max-width: 600px) {
    .menu-tabs {
      flex-wrap: wrap;
    }
    
    .menu-tab {
      flex: 1 1 calc(33% - 8px);
      min-width: 60px;
    }
    
    .tab-label {
      font-size: 0.75rem;
    }
  }
</style>
