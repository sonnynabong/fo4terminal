        <p class="hint">Type 'help' for available commands or click on menu items below.</p>
      </div>
      <div class="quick-menu">
        <span class="menu-label">[QUICK ACCESS]</span>
        <div class="menu-items">
          <button class="menu-btn" data-cmd="about">[ABOUT]</button>
          <button class="menu-btn" data-cmd="skills">[SKILLS]</button>
          <button class="menu-btn" data-cmd="projects">[PROJECTS]</button>
